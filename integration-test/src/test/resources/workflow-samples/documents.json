{
  "input": {},
  "schemaVersion": "1.0",
  "steps": [
    {
      "id": "createSite",
      "idempotencyKey": "sample-doc-site-1",
      "onError": {
        "policy": "FAIL_FAST"
      },
      "operation": "site.create",
      "params": [
        {
          "name": "count",
          "value": 1
        },
        {
          "name": "baseName",
          "value": "sample-doc-site"
        }
      ]
    },
    {
      "id": "createDocument",
      "idempotencyKey": "sample-document-1",
      "onError": {
        "policy": "FAIL_FAST"
      },
      "operation": "document.create",
      "params": [
        {
          "name": "count",
          "value": 2
        },
        {
          "name": "baseName",
          "value": "sample-workflow-document"
        },
        {
          "name": "groupId",
          "from": "steps.createSite.items[0].groupId"
        },
        {
          "name": "description",
          "value": "Sample document generated by workflow template."
        }
      ]
    }
  ],
  "workflowId": "sample-documents"
}
